# Copy this file to .env and fill in your own values.
# NEVER commit .env to git — it is already in .gitignore.

PORT=5000
NODE_ENV=development

# ── JWT ────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# ── Database ────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (URI)
# Development: use direct connection port 5432
# Production on Vercel: use Transaction mode pooler port 6543
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Amazon Associates ───────────────────────────────────────
# Apply at: affiliate-program.amazon.com
# Format: yourstore-20  (get your own — never use someone else's tag)
AMAZON_AFFILIATE_TAG=your-store-id-20

# ── Google AdSense ──────────────────────────────────────────
# Your publisher ID from AdSense → Account → Account information
# NOTE: this ID is also embedded in client/index.html for the AdSense script tag
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
