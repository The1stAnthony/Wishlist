# Copy this to .env and fill in your values

PORT=5000
NODE_ENV=development

# Generate a long random string (32+ chars)
JWT_SECRET=replace_with_a_long_random_secret

# Supabase → Settings → Database → Connection string (URI)
# Development: use port 5432 (Session mode)
# Production on Vercel: use port 6543 (Transaction mode pooler)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres

# Amazon Associates tag (affiliate-program.amazon.com)
AMAZON_AFFILIATE_TAG=alliwant-20

# Google AdSense publisher ID
ADSENSE_CLIENT_ID=ca-pub-5976607298154940
