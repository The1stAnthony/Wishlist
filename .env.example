# Copy this file to .env and fill in your values
# .env is gitignored — never commit your real keys

# ── Server ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Generate a long random string — used to sign JWT tokens
# Example: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret

# ── Amazon Affiliate ────────────────────────────────────────
# Sign up free at https://affiliate-program.amazon.com
# Your tag looks like: yourname-20
AMAZON_AFFILIATE_TAG=alliwant-20

# ── Google AdSense ──────────────────────────────────────────
# Apply at https://adsense.google.com
# Your ID looks like: ca-pub-1234567890123456
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXXX
