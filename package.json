{
  "name": "alliwant",
  "version": "1.0.0",
  "description": "AllIWant — birthday registry and gift wishlist platform",
  "scripts": {
    "dev":         "concurrently --names \"server,client\" --prefix-colors \"magenta,cyan\" \"npm run server\" \"npm run client\"",
    "server":      "node api/index.js",
    "client":      "npm --prefix client run dev",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "bcryptjs":    "^2.4.3",
    "cors":        "^2.8.5",
    "dotenv":      "^16.4.5",
    "express":     "^4.18.3",
    "jsonwebtoken":"^9.0.2",
    "pg":          "^8.22.0",
    "uuid":        "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
